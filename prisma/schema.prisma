generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TxType {
  DEPOSIT
  BUY
  SELL
  SCORE_PAYOUT
  ADJUSTMENT
}

enum OrderSide {
  BUY
  SELL
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model User {
  id            String                 @id @default(cuid())
  name          String?
  email         String?                @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  wallet        Wallet?
  holdings      Holding[]
  lineups       WeeklyLineup[]
  weeklyScores  WeeklyUserScore[]
  seasonScores  SeasonUserScore[]
  transactions  WalletTransaction[]
  trades        Trade[]
  accounts      Account[]
  sessions      Session[]

  @@index([createdAt])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @db.Decimal(20, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id             String   @id @default(cuid())
  userId         String
  type           TxType
  amount         Decimal  @db.Decimal(20, 6)
  balanceAfter   Decimal  @db.Decimal(20, 6)
  referenceType  String
  referenceId    String
  createdAt      DateTime @default(now())
  idempotencyKey String?  @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Artist {
  id            String             @id @default(cuid())
  slug          String             @unique
  name          String
  genre         String
  imageUrl      String?
  description   String?
  basePrice     Decimal            @db.Decimal(20, 6)
  kFactor       Decimal            @db.Decimal(20, 6)
  supply        Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  holdings      Holding[]
  trades        Trade[]
  lineupEntries WeeklyLineupEntry[]
  weeklyMetrics WeeklyArtistMetric[]

  @@index([name])
}

model Holding {
  id        String   @id @default(cuid())
  userId    String
  artistId  String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId])
}

model Trade {
  id             String    @id @default(cuid())
  userId         String
  artistId       String
  side           OrderSide
  quantity       Int
  grossAmount    Decimal   @db.Decimal(20, 6)
  supplyBefore   Int
  supplyAfter    Int
  createdAt      DateTime  @default(now())
  idempotencyKey String?   @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, createdAt])
  @@index([userId, createdAt])
}

model Week {
  id            String             @id
  startAt       DateTime
  endAt         DateTime
  lineupLockAt  DateTime
  seasonId      String
  createdAt     DateTime           @default(now())
  lineups       WeeklyLineup[]
  artistMetrics WeeklyArtistMetric[]
  userScores    WeeklyUserScore[]

  @@index([startAt])
}

model Season {
  id          String            @id
  name        String
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime          @default(now())
  weeks       Week[]
  userScores  SeasonUserScore[]
}

model WeeklyLineup {
  id        String             @id @default(cuid())
  userId    String
  weekId    String
  lockedAt  DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  week      Week               @relation(fields: [weekId], references: [id], onDelete: Cascade)
  entries   WeeklyLineupEntry[]

  @@unique([userId, weekId])
}

model WeeklyLineupEntry {
  id        String       @id @default(cuid())
  lineupId  String
  artistId  String
  position  Int
  createdAt DateTime     @default(now())
  lineup    WeeklyLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  artist    Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([lineupId, artistId])
  @@unique([lineupId, position])
}

model WeeklyArtistMetric {
  id        String   @id @default(cuid())
  weekId    String
  artistId  String
  score     Decimal  @db.Decimal(20, 6)
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([weekId, artistId])
}

model WeeklyUserScore {
  id        String   @id @default(cuid())
  weekId    String
  userId    String
  score     Decimal  @db.Decimal(20, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  week      Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weekId, userId])
  @@index([weekId, score])
}

model SeasonUserScore {
  id        String   @id @default(cuid())
  seasonId  String
  userId    String
  score     Decimal  @db.Decimal(20, 6)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId, score])
}

model ScoringJob {
  id        String    @id @default(cuid())
  weekId    String
  status    JobStatus @default(PENDING)
  runAt     DateTime  @default(now())
  finishedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([weekId])
}

// NextAuth v5 tables
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
